# Claude Dashboard - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Everything works with ZERO config out of the box.
# The dashboard reads ~/.claude/ directly. No database, no account needed.
# Only uncomment what you need.
# ─────────────────────────────────────────────────────────────────────────────

# ── Port ────────────────────────────────────────────────────────────────────
# Default: 3000 (npm run dev) or 3003 (npm run dev:full / prod)
# PORT=3000

# ── Password Protection ─────────────────────────────────────────────────────
# Set to require a password before accessing the dashboard.
# ADMIN_PASSWORD=your-secret-here
# ADMIN_EMAIL=admin

# ── Multi-Machine Mode ──────────────────────────────────────────────────────
# Connect multiple machines running Claude Dashboard into one view.
# MODE=admin
# MACHINES=10.0.0.57:3003,10.0.0.97:3003
# LOCAL_MACHINE_ID=macbook

# ── Database (optional) ─────────────────────────────────────────────────────
# SQLite for session history and machine sync. Auto-created if missing.
# SQLITE_PATH=~/.claude/dashboard.db
# MACHINES_DB_PATH=/path/to/shared.db

# ── RAG Memory ──────────────────────────────────────────────────────────────
# Directory containing your projects (for RAG ingestion).
# Defaults to ~/Sites if not set.
# RAG_PROJECTS_DIR=~/Sites

# ── Local Apps Integration ──────────────────────────────────────────────────
# Port for the local-apps monitor (optional).
# LOCAL_APPS_PORT=9876
